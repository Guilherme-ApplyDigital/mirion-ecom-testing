BASIC_AUTH_USERNAME=apply-mirion
BASIC_AUTH_PASSWORD=ApplyDigitalMirion2025
MIRION_BASE_URL=https://sandbox.storefront.miriontest.net
NODE_ENV=

# Email used in storefront login form (must be allowlisted in Mirion storefront).
MIRION_LOGIN_EMAIL=your-allowlisted-email@company.com

# Route validated after login (depends on the user's permissions).
# Examples: /medical, /technologies. Defaults to /medical.
MIRION_POST_AUTH_PATH=/medical

# MailSlurp API settings
MAILSLURP_API_KEY=your-mailslurp-api-key
MAILSLURP_INBOX_ID=your-mailslurp-inbox-id
MAILSLURP_INBOX_EMAIL_ADDRESS=your-inbox@mailslurp.test
MAILSLURP_TIMEOUT_MS=120000

# Optional MailSlurp webmail fallback (used when API key/inbox id are not set).
MAILSLURP_WEB_EMAIL=
MAILSLURP_WEB_PASSWORD=
MAILSLURP_WEB_URL=https://app.mailslurp.com/login
MAILSLURP_FORCE_WEBMAIL=false

# Optional: use when you have a fresh magic link from another mailbox.
MIRION_MAGIC_LINK=
